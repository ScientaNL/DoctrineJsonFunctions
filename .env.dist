# Integration test database connection URLs.
# Copy this file to .env and fill in your local values,
# or set these as environment variables before running the tests.
#
# The docker-compose.yml service sets these automatically
# inside the php container.

MYSQL_URL=mysql://root:root@127.0.0.1:3307/doctrine_json_test
MARIADB_URL=mysql://root:root@127.0.0.1:3308/doctrine_json_test
POSTGRES_URL=pgsql://postgres:postgres@127.0.0.1:5433/doctrine_json_test

# SQLite runs in-memory and requires no configuration.
