{
    "name": "scienta/doctrine-json-functions",
    "abandoned": false,
    "type": "library",
    "description": "A set of extensions to Doctrine that add support for json query functions.",
    "keywords": [
        "doctrine",
        "orm",
        "json",
        "dql",
        "database",
        "mysql",
        "postgres",
        "postgresql",
        "mariadb",
        "sqlite"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Doctrine Json Functions Contributors",
            "homepage": "https://github.com/ScientaNL/DoctrineJsonFunctions/contributors"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "doctrine/dbal": "^3.2 || ^4",
        "doctrine/lexer": "^2.0 || ^3.0",
        "doctrine/orm": "^2.19 || ^3"
    },
    "require-dev": {
        "doctrine/coding-standard": "^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.5",
        "psalm/plugin-phpunit": "^0.19",
        "slevomat/coding-standard": "~8",
        "symfony/cache": "^5.4 || ^6.4 || ^7.4 || ^8.0",
        "symfony/var-exporter": "^6.4 || ^7.4 || ^8.0",
        "vimeo/psalm": "^6.15",
        "webmozart/assert": "^1.9.1 || ^2.1"
    },
    "autoload": {
        "psr-4": {
            "Scienta\\DoctrineJsonFunctions\\": "src/"
        },
        "files": ["polyfill/override.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Doctrine\\Tests\\": "tests/Doctrine/Tests",
            "Scienta\\DoctrineJsonFunctions\\Tests\\": "tests/"
        }
    },
    "suggest": {
        "dunglas/doctrine-json-odm": "To serialize / deserialize objects as JSON documents."
    },
    "scripts": {
        "codestyle": "phpcs -q --report=checkstyle",
        "phpcs": "phpcs -q --report=checkstyle",
        "phpstan": "phpstan analyze -v --memory-limit=512M",
        "psalm": "psalm --config=psalm.xml",
        "test:unit": "./vendor/bin/phpunit --testsuite unit",
        "test:integration": "./vendor/bin/phpunit --testsuite integration-mysql,integration-mariadb,integration-postgresql,integration-sqlite",
        "test:integration:mysql": "./vendor/bin/phpunit --testsuite integration-mysql",
        "test:integration:mariadb": "./vendor/bin/phpunit --testsuite integration-mariadb",
        "test:integration:postgres": "./vendor/bin/phpunit --testsuite integration-postgresql",
        "test:integration:sqlite": "./vendor/bin/phpunit --testsuite integration-sqlite"
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
